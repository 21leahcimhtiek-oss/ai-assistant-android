# Core
DATABASE_URL=mysql://user:password@localhost:3306/mindspace
JWT_SECRET=your-jwt-secret
ADMIN_SECRET=your-admin-secret
APP_URL=https://therapyhub.app
PORT=3000

# Manus OAuth (server)
VITE_APP_ID=your-manus-app-id
VITE_OAUTH_PORTAL_URL=https://portal.example.com
OAUTH_SERVER_URL=https://oauth.example.com
OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=Your Owner Name
BUILT_IN_FORGE_API_URL=https://forge.example.com
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Expo public (client)
EXPO_PUBLIC_APP_ID=your-manus-app-id
EXPO_PUBLIC_OAUTH_PORTAL_URL=https://portal.example.com
EXPO_PUBLIC_OAUTH_SERVER_URL=https://oauth.example.com
EXPO_PUBLIC_OWNER_OPEN_ID=your-owner-open-id
EXPO_PUBLIC_OWNER_NAME=Your Owner Name
EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# Expo dev/runtime
EXPO_PACKAGER_PROXY_URL=https://expo.dev
EXPO_WEB_PREVIEW_URL=https://expo.dev
EXPO_PUSH_TOKEN=your-expo-push-token
EXPO_TOKEN=your-expo-token

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://example.com/auth/google/callback
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_REDIRECT_URI=https://example.com/auth/apple/callback

# AI / OpenRouter
OPENROUTER_API_KEY=sk-or-your-api-key

# Payments (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_PREMIUM=price_your_premium_price_id

# Email
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@therapyhub.app

# Analytics
MIXPANEL_TOKEN=your-mixpanel-token

# Streaming
STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret
